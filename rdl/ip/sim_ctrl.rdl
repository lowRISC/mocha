addrmap sim_ctrl {
  external mem {
    mementries = 0x01; memwidth=32;
    desc = "Write the simulation status";
  } TEST_STATUS @ 0x80 ;

  external mem {
    mementries = 0x01; memwidth=32;
    desc = "The simulation log struct";
  } LOG;
};
